{
    // 터미널의 기본 작업 디렉토리 설정
    "terminal.integrated.cwd": "${workspaceFolder}",
    
    // 또는 특정 경로로 설정하려면:
    // "terminal.integrated.cwd": "C:\\tradingbot",
    
    // 새 터미널이 열릴 때마다 이 디렉토리로 이동
    "terminal.integrated.defaultLocation": "workspaceFolder",
    
    // ==================== 탭 관리 설정 ====================
    
    // Preview Mode 완전 비활성화 - 새 파일을 열 때 기존 탭이 사라지지 않도록
    "workbench.editor.enablePreview": false,
    
    // 파일을 더블클릭하거나 탐색기에서 열 때도 Preview Mode 비활성화
    "workbench.editor.enablePreviewFromQuickOpen": false,
    
    // 파일 탐색기에서 파일을 열 때 Preview Mode 비활성화
    "workbench.editor.enablePreviewFromCodeNavigation": false,
    
    // 파일 탐색기에서 단일 클릭 동작 설정
    // "singleClick" - 단일 클릭으로 파일 열기 (Preview Mode 비활성화 시 일반 탭으로 열림)
    // "doubleClick" - 더블 클릭으로만 파일 열기
    "workbench.list.openMode": "singleClick",
    
    // 위의 enablePreview: false 설정과 함께 사용하면
    // 단일 클릭으로 파일을 열어도 Preview Mode가 아닌 일반 탭으로 열림
    
    // 탭을 닫을 때 동작 설정
    "workbench.editor.closeOnFileDelete": false,
    
    // 탭이 너무 많을 때 자동으로 닫히지 않도록
    "workbench.editor.limit.enabled": false,
    
    // 탭 그룹이 닫힐 때 동작
    "workbench.editor.closeEmptyGroups": false,
    
    // 탭을 열 때 동작 설정
    // false: 항상 새 탭으로 열기 (기존 탭 교체 방지)
    // true: 이미 열려있으면 해당 탭으로 이동 (탭 교체 가능)
    "workbench.editor.revealIfOpen": false,
    
    // 다른 그룹에 열려있어도 새 탭으로 열기
    "workbench.editor.revealIfOpenInAnotherGroup": false,
    
    // 새 탭이 열리는 위치 설정
    // "right" - 오른쪽에 새 탭 추가
    // "left" - 왼쪽에 새 탭 추가
    // "last" - 마지막에 새 탭 추가
    "workbench.editor.openPositioning": "right",
    
    // 탭이 열려있을 때도 새 탭으로 열기
    "workbench.editor.focusRecentEditorAfterClose": false,
    
    // 탭 닫기 동작 - 단일 클릭으로 닫기 비활성화
    "workbench.editor.tabCloseButton": "right",
    
    // 탭 스와이프로 닫기 비활성화 (Mac)
    "workbench.editor.tabSizing": "fit",
    
    // ==================== UI 설정 ====================
    
    // 메뉴바 표시 (Windows/Linux)
    "window.menuBarVisibility": "default",
    "workbench.editor.tabActionLocation": "right",
    
    // 메뉴바 표시 (Mac)
    // "window.menuBarVisibility": "visible",
    
    // 주의: workbench.editor.tabActionLocation은 워크스페이스 설정에서 지원되지 않습니다.
    // 이 설정이 필요하면 전역 사용자 설정에서만 사용하세요.
}

